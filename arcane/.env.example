JWT_SECRET=         # Required - 64-char hex string for JWT token signing
SECRET_KEY=         # Required - 48-char hex string for Flask session encryption
SUPABASE_URL=       # Your_project_url_here
SUPABASE_KEY=       # Your_anon_key_here